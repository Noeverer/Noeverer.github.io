# Wiki.js 环境变量配置示例
# 复制此文件为 .env 并修改相应值

# 数据库配置
DB_TYPE=postgres
DB_HOST=postgres
DB_PORT=5432
DB_USER=wikijs
DB_PASS=wikijs_password
DB_NAME=wikijs

# Git 仓库配置
GITHUB_USERNAME=your_username
GITHUB_REPOSITORY=your_repository
GIT_BRANCH=main

# 访问配置
WIKI_PORT=3000
WIKI_HOST=localhost

# 时区配置
TZ=Asia/Shanghai

# Git 认证方式: ssh 或 basic
GIT_AUTH_TYPE=ssh

# GitHub Personal Access Token (仅用于 basic 认证)
GITHUB_TOKEN=your_personal_access_token

# 日志级别: debug, info, warn, error
LOG_LEVEL=info
